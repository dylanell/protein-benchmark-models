{
    "seed": 42,
    "data": {
        "train_path": "s3://data/tape/fluorescence/train.csv",
        "valid_path": "s3://data/tape/fluorescence/valid.csv",
        "task_type": "tokenized"
    },
    "model": {
        "name": "cnn_regressor",
        "params": {
            "embed_dims": [
                22,
                64
            ],
            "kernel_spec": [
                [
                    3,
                    32,
                    1
                ],
                [
                    3,
                    64,
                    1
                ],
                [
                    3,
                    128,
                    2
                ]
            ],
            "output_dim": 1,
            "hidden_activation": "LeakyReLU",
            "output_activation": "Identity",
            "use_bias": true,
            "norm": "layer"
        }
    },
    "training": {
        "experiment_name": "tape_fluorescence_regression",
        "run_name": null,
        "model_path": ".models/tape_fluorescence_cnn_regressor",
        "lr": 0.0001,
        "weight_decay": 0.01,
        "max_epochs": 1000,
        "batch_size": 256,
        "patience": 25,
        "tracking": true
    }
}