{
    "seed": 42,
    "data": {
        "train_path": "s3://data/bernett_ppi/train.csv",
        "valid_path": "s3://data/bernett_ppi/valid.csv",
        "task_type": "paired_onehot",
        "seq_len": 4096
    },
    "model": {
        "name": "siamese_mlp_classifier",
        "params": {
            "encoder_dims": [
                512,
                128
            ],
            "head_dims": [
                256,
                1
            ],
            "hidden_activation": "LeakyReLU",
            "output_activation": "Identity",
            "use_bias": true,
            "norm": "layer"
        }
    },
    "training": {
        "experiment_name": "bernett_ppi_classification",
        "run_name": null,
        "model_path": "s3://models/bernett_ppi_siamese_mlp_classifier",
        "lr": 0.001,
        "weight_decay": 0.01,
        "max_epochs": 1000,
        "batch_size": 256,
        "val_frequency": 1,
        "patience": 25,
        "tracking": true
    }
}