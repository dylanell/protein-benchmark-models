{
    "seed": 42,
    "data": {
        "train_path": ".data/flip2/amylase/random_split/train.csv",
        "valid_path": ".data/flip2/amylase/random_split/valid.csv",
        "dataset_type": "tokenized"
    },
    "model": {
        "name": "cnn_regressor",
        "params": {
            "embed_dims": [22, 64],
            "kernel_spec": [
                [3, 32, 1], 
                [3, 64, 1],
                [3, 128, 2]
            ],
            "output_dim": 1,
            "hidden_activation": "LeakyReLU",
            "output_activation": "Identity",
            "use_bias": true,
            "norm": "layer"
        }
    },
    "training": {
        "experiment_name": "flip2_amylase_random_split_regression",
        "run_name": null,
        "model_path": ".models/flip2_amylase_random_split_cnn_regressor",
        "lr": 1e-4,
        "weight_decay": 0.01,
        "max_epochs": 5,
        "batch_size": 256,
        "patience": 25,
        "tracking": true
    }
}
