{
    "seed": 42,
    "data": {
        "train_path": ".data/bernett_ppi/train.csv",
        "valid_path": ".data/bernett_ppi/valid.csv",
        "dataset_type": "paired_one_hot",
        "seq_len": 512
    },
    "model": {
        "name": "siamese_mlp_classifier",
        "params": {
            "encoder_dims": [128],
            "head_dims": [256, 64, 1],
            "hidden_activation": "ReLU",
            "output_activation": "Identity",
            "use_bias": true,
            "norm": "layer"
        }
    },
    "training": {
        "experiment_name": "bernett_ppi_classification",
        "run_name": null,
        "model_path": ".models/bernett_ppi_siamese_mlp_classifier",
        "lr": 0.001,
        "weight_decay": 0.01,
        "max_epochs": 20,
        "batch_size": 256,
        "val_frequency": 1,
        "patience": 5,
        "tracking": false
    }
}
