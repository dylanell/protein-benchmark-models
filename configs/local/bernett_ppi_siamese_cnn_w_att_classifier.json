{
    "seed": 42,
    "data": {
        "train_path": ".data/bernett_ppi/train.csv",
        "valid_path": ".data/bernett_ppi/valid.csv",
        "task_type": "paired_tokenized",
        "seq_len": 4096
    },
    "model": {
        "name": "siamese_cnn_w_att_classifier",
        "params": {
            "embed_dims": [
                22,
                64
            ],
            "kernel_spec": [
                [
                    3,
                    32,
                    1
                ],
                [
                    3,
                    64,
                    1
                ],
                [
                    3,
                    128,
                    2
                ]
            ],
            "num_attention_heads": 8,
            "head_dims": [
                256,
                64,
                1
            ],
            "hidden_activation": "ReLU",
            "output_activation": "Identity",
            "use_bias": true,
            "norm": "batch",
            "attention_dropout": 0.1
        }
    },
    "training": {
        "experiment_name": "bernett_ppi_classification",
        "run_name": null,
        "model_path": ".models/bernett_ppi_siamese_cnn_w_att_classifier",
        "lr": 0.0001,
        "weight_decay": 0.01,
        "max_epochs": 50,
        "batch_size": 256,
        "val_frequency": 1,
        "patience": 10,
        "tracking": true
    }
}