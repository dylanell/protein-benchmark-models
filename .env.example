# =============================================================================
# Option A: Local (Docker Compose on your machine)
# Run: docker compose up -d
# MLflow UI: http://localhost:5000
# MinIO console: http://localhost:7001
# =============================================================================
# MLFLOW_TRACKING_URI=http://localhost:5000
# S3_ENDPOINT_URL=http://localhost:7000
# MLFLOW_S3_ENDPOINT_URL=http://localhost:7000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# =============================================================================
# Option B: Remote (Docker Compose on a GCE VM)
# Same docker-compose.yaml deployed on a VM with a public IP.
# Replace <vm-ip> with your VM's external IP address.
# MLflow UI: http://<vm-ip>:5000
# MinIO console: http://<vm-ip>:7001
# =============================================================================
# MLFLOW_TRACKING_URI=http://<vm-ip>:5000
# S3_ENDPOINT_URL=http://<vm-ip>:7000
# MLFLOW_S3_ENDPOINT_URL=http://<vm-ip>:7000
# AWS_ACCESS_KEY_ID=<your-minio-access-key>
# AWS_SECRET_ACCESS_KEY=<your-minio-secret-key>

# MLFLOW_TRACKING_URI=http://34.42.116.216:5000
# S3_ENDPOINT_URL=http://34.42.116.216:7000
# MLFLOW_S3_ENDPOINT_URL=http://34.42.116.216:7000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
